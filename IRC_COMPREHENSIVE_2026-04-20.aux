\newlabel{fig:main_conv}{{1}{3}{\textbf {Convergence rate vs.\ TS noise, five methods.} Fraction of the 300-sample universe where each method's own local gate fires within 2000 steps. \emph {Left tier} (upper two lines, blue/cyan): GAD with and without Eckart. \emph {Middle tier} (red, orange): Sella Cartesian, with or without Eckart. \emph {Bottom tier} (purple): Sella in internal coordinates. The gap grows monotonically with noise.\relax }{figure.caption.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Convergence rates (\% of 300) by method and noise.} All at 2000 steps, HIP Hessian every step.\relax }}{3}{table.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Rank-ordering is strictly preserved across noise.}{3}{section*.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Eckart projection's contribution: $\Delta $conv.\ rate (with Eckart minus without).} For GAD, Eckart adds consistently positive value (+3--9\,pp, growing with noise). For Sella Cartesian, the delta is within $\pm $1.5\,pp at every noise level --- i.e.\ statistically a wash.\relax }}{4}{figure.caption.4}\protected@file@percent }
