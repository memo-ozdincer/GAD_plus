\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {Step ratio (no-Eckart / Eckart) per noise level, on shared converged samples.} Boxes are 25--75 percentiles, whiskers are full range. Median (orange line) sits at 0.91--0.97 across noise levels. The dashed line at 1.0 is "tied"; values below indicate no-Eckart is faster.\relax }}{18}{figure.caption.21}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \textbf  {Distribution of \texttt  {converged\_step} for samples that converged under each method, log $x$-axis.} Eckart and no-Eckart distributions overlap heavily; no-Eckart sits slightly to the left (fewer steps) at every noise. The right tail at 150/200\,pm is what drives the small differences in convergence rate.\relax }}{19}{figure.caption.23}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {14}{\ignorespaces \textbf  {Per-noise breakdown of the 4-quadrant agreement.} Green = converges under both; blue = only Eckart; cyan = only no-Eckart; red = neither. Stacks always sum to 300. The cyan layer is consistently larger than blue at low noise (no-Eckart converges more samples); the green floor erodes from 300 down to 103 as noise grows.\relax }}{20}{figure.caption.25}\protected@file@percent }
