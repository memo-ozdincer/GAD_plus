\@writefile{toc}{\contentsline {subsection}{\numberline {2.2}Sella's coordinate-system dilemma}{4}{subsection.2.2}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Why does internal hurt here?}{4}{section*.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Sella in Cartesian vs.\ internal coords (no Eckart in either).} Internal coords are Sella's library default and conventional wisdom says they should beat Cartesian for TS search. On HIP with Hessian every step they lose --- and the gap grows from 4.6\,pp at 10\,pm to 18\,pp at 150\,pm.\relax }}{5}{figure.caption.6}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3}Compute costs}{5}{section.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Compute economics.} Sella Cartesian is fastest per sample at low noise ($\sim $13\,s), but its high-noise convergence rate collapse inverts the per-hour yield: at 200\,pm, GAD Eckart delivers $\sim $22 TSs/GPU-h vs Sella Cartesian's $\sim $8.\relax }}{5}{figure.caption.8}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Cross-over point $\approx $100\,pm.}{6}{section*.9}\protected@file@percent }
