\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {Every method, on one canvas.} Left: GAD family (dt grid + adaptive + low-dt). Right: Sella family (libdef cart, default cart, internal coords, Hessian cadences d=3/10/25, matched-budget 5k, no-Hessian partial). Same gate ($n_{\text  {neg}}{=}1\,\wedge \,f_{\qopname  \relax m{max}}{<}0.01$), test n=287. Color coding: each family stays in one warm/cool palette so the eye can group them. The ``no HIP H'' (BFGS only) line at the bottom of the right panel is partial (timed out at 12h with $\sim $5\% conv at every noise).\relax }}{27}{figure.caption.86}\protected@file@percent }
\newlabel{fig:full-sweep}{{10}{27}{\textbf {Every method, on one canvas.} Left: GAD family (dt grid + adaptive + low-dt). Right: Sella family (libdef cart, default cart, internal coords, Hessian cadences d=3/10/25, matched-budget 5k, no-Hessian partial). Same gate ($n_{\text {neg}}{=}1\,\wedge \,f_{\max }{<}0.01$), test n=287. Color coding: each family stays in one warm/cool palette so the eye can group them. The ``no HIP H'' (BFGS only) line at the bottom of the right panel is partial (timed out at 12h with $\sim $5\% conv at every noise).\relax }{figure.caption.86}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Sella's three hyperparameter axes, each varied alone. (A) hyperparameter only ($\delta _0,\gamma $): minor effect. (B) coordinate system (internal vs Cartesian + Eckart): $\sim $10pp drop at high noise — this is an algorithm change, not a hparam tweak. (C) HIP H injection cadence (every 1, 3, 10, 25 steps, vs none): smooth degradation across $N=1\to 25$ ($-$3 to $-$13pp at 100--150pm), then a cliff to $\sim $5\% when no Hessian at all. The first 1-of-25 HIP Hessian per chain is what's load-bearing, not ``every step.''\relax }}{27}{figure.caption.87}\protected@file@percent }
\newlabel{fig:sella-variants}{{11}{27}{Sella's three hyperparameter axes, each varied alone. (A) hyperparameter only ($\delta _0,\gamma $): minor effect. (B) coordinate system (internal vs Cartesian + Eckart): $\sim $10pp drop at high noise — this is an algorithm change, not a hparam tweak. (C) HIP H injection cadence (every 1, 3, 10, 25 steps, vs none): smooth degradation across $N=1\to 25$ ($-$3 to $-$13pp at 100--150pm), then a cliff to $\sim $5\% when no Hessian at all. The first 1-of-25 HIP Hessian per chain is what's load-bearing, not ``every step.''\relax }{figure.caption.87}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces GAD's hyperparameter axes. (A) dt grid at fixed 5000-step budget: monotone improvement from dt=0.003 to dt=0.007; collapse at dt=0.008 from Euler instability ($dt < 2/|\lambda _{\qopname  \relax m{max}}|$ is violated by stiff bond modes). (B) Step-budget tradeoff: dt=0.007/5k beats dt=0.003/5k beats adaptive\_dt; very-small-dt rows (1e-3, 5e-4 with 20k--40k step budgets) are partial coverage and confirm the structural plateau — 70$\times $ dt drop changes conv by $\le $5pp.\relax }}{28}{figure.caption.88}\protected@file@percent }
\newlabel{fig:gad-lineage}{{12}{28}{GAD's hyperparameter axes. (A) dt grid at fixed 5000-step budget: monotone improvement from dt=0.003 to dt=0.007; collapse at dt=0.008 from Euler instability ($dt < 2/|\lambda _{\max }|$ is violated by stiff bond modes). (B) Step-budget tradeoff: dt=0.007/5k beats dt=0.003/5k beats adaptive\_dt; very-small-dt rows (1e-3, 5e-4 with 20k--40k step budgets) are partial coverage and confirm the structural plateau — 70$\times $ dt drop changes conv by $\le $5pp.\relax }{figure.caption.88}{}}
